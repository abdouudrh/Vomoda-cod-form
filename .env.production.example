NODE_ENV=production
PORT=3000
DATABASE_URL="postgresql://vomoda:change_me@postgres:5432/vomoda_cod?schema=public"

SHOPIFY_API_KEY="your_shopify_api_key"
SHOPIFY_API_SECRET="your_shopify_api_secret"
SCOPES="read_orders,write_orders,write_draft_orders,write_products,write_metaobjects,write_metaobject_definitions"
SHOPIFY_APP_URL="https://app.your-domain.com"

# Optional
SHOP_CUSTOM_DOMAIN=""
APP_DOMAIN="app.your-domain.com"
POSTGRES_DB="vomoda_cod"
POSTGRES_USER="vomoda"
POSTGRES_PASSWORD="change_me"
