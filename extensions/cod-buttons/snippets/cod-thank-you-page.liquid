<div id="cod-thank-you-page"></div>

<style>
  #cod-thank-you-page {
    min-height: 100vh;
    background: #ffffff;
    color: #111111;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }

  .cod-ty-shell {
    display: grid;
    grid-template-columns: minmax(0, 1.02fr) minmax(360px, 0.82fr);
    min-height: 100vh;
  }

  .cod-ty-main {
    padding: 42px 36px 40px;
    background: #ffffff;
  }

  .cod-ty-side {
    padding: 44px 38px;
    background: #fafafa;
    border-left: 1px solid #e5e5e5;
  }

  .cod-ty-container {
    max-width: 540px;
    margin-left: auto;
  }

  .cod-ty-header {
    display: flex;
    gap: 18px;
    align-items: flex-start;
    margin-bottom: 28px;
  }

  .cod-ty-check {
    width: 46px;
    height: 46px;
    border-radius: 999px;
    border: 2px solid #ff6a1a;
    color: #ff6a1a;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    font-size: 24px;
    font-weight: 700;
    line-height: 1;
  }

  .cod-ty-confirmation-label {
    font-size: 15px;
    color: #6b7280;
    margin-bottom: 2px;
  }

  .cod-ty-order-number {
    font-size: 34px;
    line-height: 1.05;
    font-weight: 800;
    letter-spacing: 0.02em;
    margin-bottom: 8px;
    color: #111111;
  }

  .cod-ty-title {
    font-size: 22px;
    line-height: 1.2;
    font-weight: 700;
    margin: 0;
    color: #111111;
  }

  .cod-ty-card {
    background: #ffffff;
    border: 1px solid #d9d9d9;
    border-radius: 14px;
    padding: 18px 16px;
    margin-bottom: 14px;
    box-shadow: 0 0 0 0 rgba(0,0,0,0);
  }

  .cod-ty-card-title {
    font-size: 16px;
    line-height: 1.25;
    font-weight: 700;
    margin: 0 0 12px;
    color: #111111;
  }

  .cod-ty-message {
    font-size: 17px;
    line-height: 1.45;
    font-weight: 600;
    margin: 0 0 10px;
    color: #111111;
  }

  .cod-ty-submessage {
    font-size: 15px;
    line-height: 1.6;
    margin: 0;
    color: #111111;
  }

  .cod-ty-submessage strong {
    color: #ff6a1a;
    font-weight: 700;
  }

  .cod-ty-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px 28px;
  }

  .cod-ty-block-title {
    font-size: 13px;
    line-height: 1.3;
    font-weight: 700;
    margin: 0 0 10px;
    color: #111111;
  }

  .cod-ty-lines {
    display: grid;
    gap: 4px;
    font-size: 15px;
    line-height: 1.55;
    color: #111111;
  }

  .cod-ty-payment-chip {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 34px;
    height: 24px;
    padding: 0 8px;
    border-radius: 7px;
    border: 1px solid #d9d9d9;
    background: #f5f5f5;
    color: #666666;
    font-size: 12px;
    margin-bottom: 8px;
  }

  .cod-ty-actions {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    margin-top: 28px;
  }

  .cod-ty-help {
    font-size: 14px;
    color: #111111;
  }

  .cod-ty-help a,
  .cod-ty-privacy {
    color: #ff6a1a;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .cod-ty-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 72px;
    padding: 0 24px;
    border-radius: 10px;
    background: #ff6a1a;
    color: #ffffff;
    text-decoration: none;
    font-size: 16px;
    font-weight: 700;
    white-space: nowrap;
  }

  .cod-ty-divider {
    border: 0;
    border-top: 1px solid #dfdfdf;
    margin: 140px 0 18px;
  }

  .cod-ty-side-wrap {
    max-width: 404px;
    margin-right: auto;
  }

  .cod-ty-item {
    display: grid;
    grid-template-columns: 64px minmax(0, 1fr) auto;
    gap: 14px;
    align-items: start;
    margin-bottom: 18px;
  }

  .cod-ty-thumb-wrap {
    position: relative;
    width: 64px;
    height: 64px;
    border-radius: 14px;
    background: #ffffff;
    border: 1px solid #d9d9d9;
    overflow: visible;
  }

  .cod-ty-thumb-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    border-radius: 14px;
  }

  .cod-ty-qty {
    position: absolute;
    top: -10px;
    right: -10px;
    min-width: 34px;
    height: 28px;
    padding: 0 8px;
    border-radius: 999px;
    background: #111111;
    color: #ffffff;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 2px solid #ffffff;
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.12);
    font-size: 12px;
    font-weight: 700;
    line-height: 1;
    white-space: nowrap;
  }

  .cod-ty-item-title {
    font-size: 15px;
    line-height: 1.45;
    font-weight: 500;
    color: #111111;
    margin: 0 0 2px;
  }

  .cod-ty-item-variant {
    font-size: 14px;
    line-height: 1.45;
    color: #666666;
    margin: 0;
  }

  .cod-ty-item-price {
    font-size: 15px;
    line-height: 1.45;
    font-weight: 500;
    white-space: nowrap;
    color: #111111;
  }

  .cod-ty-summary {
    margin-top: 24px;
    display: grid;
    gap: 10px;
  }

  .cod-ty-summary-row {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 16px;
    font-size: 15px;
    line-height: 1.45;
    color: #111111;
  }

  .cod-ty-summary-row span:last-child {
    white-space: nowrap;
  }

  .cod-ty-summary-total {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 16px;
    margin-top: 10px;
    padding-top: 16px;
    border-top: 1px solid #d9d9d9;
  }

  .cod-ty-summary-total-label {
    font-size: 18px;
    font-weight: 700;
  }

  .cod-ty-summary-total-value {
    display: flex;
    align-items: baseline;
    gap: 8px;
    white-space: nowrap;
  }

  .cod-ty-currency {
    font-size: 14px;
    color: #7b7b7b;
  }

  .cod-ty-total-money {
    font-size: 18px;
    font-weight: 800;
    color: #111111;
  }

  .cod-ty-empty {
    max-width: 680px;
    margin: 72px auto;
    padding: 28px 22px;
    border: 1px solid #d9d9d9;
    border-radius: 14px;
    background: #ffffff;
    text-align: center;
  }

  .cod-ty-empty h2 {
    font-size: 24px;
    margin: 0 0 12px;
  }

  .cod-ty-empty p {
    font-size: 15px;
    line-height: 1.6;
    margin: 0 0 18px;
    color: #555555;
  }

  @media (max-width: 990px) {
    .cod-ty-shell {
      grid-template-columns: 1fr;
    }

    .cod-ty-side {
      border-left: 0;
      border-top: 1px solid #e5e5e5;
    }

    .cod-ty-container,
    .cod-ty-side-wrap {
      max-width: none;
    }

    .cod-ty-divider {
      margin-top: 48px;
    }
  }

  @media (max-width: 640px) {
    .cod-ty-main,
    .cod-ty-side {
      padding: 24px 18px;
    }

    .cod-ty-grid {
      grid-template-columns: 1fr;
      gap: 18px;
    }

    .cod-ty-actions {
      flex-direction: column;
      align-items: stretch;
    }

    .cod-ty-button {
      width: 100%;
    }

    .cod-ty-order-number {
      font-size: 28px;
    }
  }
</style>

<script>
  (function () {
    function readThankYouData() {
      const raw = window.sessionStorage.getItem('codThankYouData') || window.localStorage.getItem('codThankYouData');
      if (!raw) return null;

      try {
        const parsed = JSON.parse(raw);
        if (!parsed || !Array.isArray(parsed.items)) {
          return null;
        }

        return parsed;
      } catch (error) {
        console.error('[COD Thank You] invalid stored data:', error);
        return null;
      }
    }

    function formatMoney(value) {
      const amount = Number(value || 0);
      return `${new Intl.NumberFormat('fr-FR', {
        minimumFractionDigits: 2,
        maximumFractionDigits: 2
      }).format(amount)} DA`;
    }

    function escapeHtml(value) {
      return String(value || '')
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');
    }

    function renderEmptyState(root) {
      root.innerHTML = `
        <div class="cod-ty-empty">
          <h2>Merci pour votre commande</h2>
          <p>Les détails de votre commande ne sont pas disponibles sur cette page pour le moment.</p>
          <a class="cod-ty-button" href="/">Retour à la boutique</a>
        </div>
      `;
    }

    function line(label) {
      return label ? `<div>${escapeHtml(label)}</div>` : '';
    }

    function renderThankYouPage(root, data) {
      const itemsCount = (data.items || []).reduce(function (sum, item) {
        return sum + (Number(item.quantity) || 0);
      }, 0);
      const customer = data.customer || {};
      const firstName = customer.firstName || customer.lastName || 'cher client';
      const storeUrl = data.storeUrl || '/';
      const privacyUrl = '/policies/privacy-policy';
      const orderNumber = (data.orderName || '').trim();
      const orderNumberHtml = orderNumber
        ? `<div class="cod-ty-order-number">${escapeHtml(orderNumber)}</div>`
        : '';
      const shippingMethodLabel = data.shippingMethodLabel || 'Livraison';
      const paymentMethodLabel = data.paymentMethodLabel || 'Paiement a la livraison';
      const subtotal = Number(data.subtotal || 0);
      const shippingPrice = Number(data.shippingPrice || 0);
      const totalValue = Number(data.totalValue || 0);
      const currency = data.currency || 'DZD';
      const contactPhone = data.contactPhone || '+213 551 639 560';

      const itemsHtml = (data.items || []).map(function (item) {
        return `
          <div class="cod-ty-item">
            <div class="cod-ty-thumb-wrap">
              ${item.image ? `<img src="${escapeHtml(item.image)}" alt="${escapeHtml(item.title)}">` : ''}
              <span class="cod-ty-qty">Qté ${escapeHtml(item.quantity || 1)}</span>
            </div>
            <div>
              <p class="cod-ty-item-title">${escapeHtml(item.title || 'Produit')}</p>
              <p class="cod-ty-item-variant">${escapeHtml(item.variantTitle || '')}</p>
            </div>
            <div class="cod-ty-item-price">${formatMoney(item.linePrice || 0)}</div>
          </div>
        `;
      }).join('');

      root.innerHTML = `
        <div class="cod-ty-shell">
          <div class="cod-ty-main">
            <div class="cod-ty-container">
              <div class="cod-ty-header">
                <div class="cod-ty-check">✓</div>
                <div>
                  <div class="cod-ty-confirmation-label">Commande N°</div>
                  ${orderNumberHtml}
                  <h1 class="cod-ty-title">Merci, ${escapeHtml(firstName)} !</h1>
                </div>
              </div>

              <div class="cod-ty-card">
                <h2 class="cod-ty-card-title">Votre commande est maintenant confirmée</h2>
                <p class="cod-ty-submessage">
                  Vous recevrez prochainement un appel de confirmation de ce numéro :
                  <strong>${escapeHtml(contactPhone)}</strong>.
                </p>
              </div>

              <div class="cod-ty-card">
                <h2 class="cod-ty-card-title">Détails de la commande</h2>
                <div class="cod-ty-grid">
                  <div>
                    <h3 class="cod-ty-block-title">Coordonnées</h3>
                    <div class="cod-ty-lines">
                      ${line(customer.email)}
                    </div>

                    <h3 class="cod-ty-block-title" style="margin-top:18px;">Adresse de livraison</h3>
                    <div class="cod-ty-lines">
                      ${line(`${customer.firstName || ''} ${customer.lastName || ''}`.trim())}
                      ${line(customer.address)}
                      ${line(`${customer.city || ''}${customer.city && customer.wilaya ? ', ' : ''}${customer.wilaya || ''}`)}
                      ${line('Algérie')}
                      ${line(customer.phone)}
                    </div>

                    <h3 class="cod-ty-block-title" style="margin-top:18px;">Mode d'expédition</h3>
                    <div class="cod-ty-lines">
                      ${line(shippingMethodLabel)}
                    </div>
                  </div>

                  <div>
                    <h3 class="cod-ty-block-title">Moyen de paiement</h3>
                    <div class="cod-ty-payment-chip">$</div>
                    <div class="cod-ty-lines">
                      ${line(`${paymentMethodLabel} · ${formatMoney(totalValue)}`)}
                      ${line(currency)}
                    </div>

                    <h3 class="cod-ty-block-title" style="margin-top:18px;">Adresse de facturation</h3>
                    <div class="cod-ty-lines">
                      ${line(`${customer.firstName || ''} ${customer.lastName || ''}`.trim())}
                      ${line(customer.address)}
                      ${line(`${customer.city || ''}${customer.city && customer.wilaya ? ', ' : ''}${customer.wilaya || ''}`)}
                      ${line('Algérie')}
                      ${line(customer.phone)}
                    </div>
                  </div>
                </div>
              </div>

              <div class="cod-ty-actions">
                <div class="cod-ty-help">
                  Besoin d’aide ? <a href="tel:+213551639560">Nous contacter</a>
                </div>
                <a class="cod-ty-button" href="${escapeHtml(storeUrl)}">Retour à la boutique</a>
              </div>

              <hr class="cod-ty-divider">
              <a class="cod-ty-privacy" href="${escapeHtml(privacyUrl)}">Politique de confidentialité</a>
            </div>
          </div>

          <aside class="cod-ty-side">
            <div class="cod-ty-side-wrap">
              ${itemsHtml}

              <div class="cod-ty-summary">
                <div class="cod-ty-summary-row">
                  <span>Sous-total · ${itemsCount} article${itemsCount > 1 ? 's' : ''}</span>
                  <span>${formatMoney(subtotal)}</span>
                </div>
                <div class="cod-ty-summary-row">
                  <span>Expédition</span>
                  <span>${formatMoney(shippingPrice)}</span>
                </div>
                <div class="cod-ty-summary-total">
                  <span class="cod-ty-summary-total-label">Total</span>
                  <span class="cod-ty-summary-total-value">
                    <span class="cod-ty-currency">${escapeHtml(currency)}</span>
                    <span class="cod-ty-total-money">${formatMoney(totalValue)}</span>
                  </span>
                </div>
              </div>
            </div>
          </aside>
        </div>
      `;
    }

    const root = document.getElementById('cod-thank-you-page');
    if (!root) return;

    const data = readThankYouData();
    if (!data) {
      renderEmptyState(root);
      return;
    }

    renderThankYouPage(root, data);
  })();
</script>
