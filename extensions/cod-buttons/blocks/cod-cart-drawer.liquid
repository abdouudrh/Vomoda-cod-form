      const shippingOptions = hasDeliveryLocation
        ? getShippingOptions(settings.shippingFees || {}, selectedWilaya)
        : [];
      const selectedMethod = getSelectedShippingMethod();
      const activeShipping = shippingOptions.find(option => option.id === selectedMethod) || shippingOptions[0] || null;
      const grandTotal = activeShipping ? subtotal + activeShipping.price : null;

