      totalEl.innerHTML = '';
    }
  }

  async function renderShippingMethods(preferredMethod = '') {
    const methodsEl = document.getElementById('cod-shipping-methods');
    const wilaya = document.getElementById('cod-wilaya')?.value || '';
    const city = document.getElementById('cod-city')?.value || '';
    if (!methodsEl) return;

    if (!wilaya || !city) {
      methodsEl.innerHTML = '';
      methodsEl.style.display = 'none';
      return;
    }

    const settings = await getMetaSettings();
    const options = getShippingOptions(settings.shippingFees || {}, wilaya);
    if (!options.length) {
      methodsEl.innerHTML = `
        <div style="padding:12px 14px;border:1px solid #fed7aa;border-radius:10px;background:#fff7ed;color:#9a3412;font-size:14px;line-height:1.5;">
          Desole, nous ne livrons pas a cette wilaya pour le moment.
        </div>
      `;
      methodsEl.style.display = 'block';
      return;
    }

    const currentMethod = preferredMethod || getSelectedShippingMethod();
    const selectedMethod = options.some(option => option.id === currentMethod)
      ? currentMethod
      : options[0].id;

    methodsEl.innerHTML = `
      <p style="font-size:13px;font-weight:600;color:#888;text-transform:uppercase;letter-spacing:.05em;margin:0 0 10px;">
        Mode de livraison
      </p>
      ${options.map(option => `
        <label style="display:flex;justify-content:space-between;align-items:center;gap:12px;padding:12px 14px;margin-bottom:8px;border:1px solid #e5e5e5;border-radius:10px;cursor:pointer;">
          <span style="display:flex;align-items:center;gap:10px;">
            <input
              type="radio"
              name="cod-shipping-method"
              value="${option.id}"
              ${selectedMethod === option.id ? 'checked' : ''}
              style="margin:0;"
            />
            <span style="font-size:14px;color:#111;">${option.label}</span>
          </span>
          <span style="font-size:14px;font-weight:600;color:#111;">${option.price.toFixed(2)} DA</span>
        </label>
      `).join('')}
    `;

    methodsEl.style.display = 'block';

    methodsEl.querySelectorAll('input[name="cod-shipping-method"]').forEach(input => {
      input.addEventListener('change', function () {
        void renderCart();
      });
    });
  }

