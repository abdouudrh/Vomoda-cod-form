    document.body.appendChild(dialog);

    function closeCod() {
      if (document.getElementById('cod-panel')?.dataset.submitting === '1') {
        return;
      }

      const panel = document.getElementById('cod-panel');
      if (panel) panel.classList.remove('cod-open');
      setTimeout(() => {
        dialog.close();
        dialog.remove();
      }, 290);
    }

    document.getElementById('cod-close').addEventListener('click', closeCod);

    dialog.addEventListener('click', function (e) {
      const panel = document.getElementById('cod-panel');
      if (panel && !panel.contains(e.target)) closeCod();
    });

    dialog.addEventListener('cancel', function (e) {
      e.preventDefault();
      closeCod();
    });

    dialog.addEventListener('click', function (e) {
      const removeButton = e.target.closest('[data-cod-remove-line]');
      if (removeButton && !isCartQuantityUpdateInFlight) {
        e.preventDefault();
        const line = removeButton.getAttribute('data-cod-remove-line');
        void handleCartLineRemoval(line);
        return;
      }

      const qtyButton = e.target.closest('[data-cod-qty-step]');
      if (!qtyButton || isCartQuantityUpdateInFlight) return;

      e.preventDefault();

      const line = qtyButton.getAttribute('data-cod-line');
      const step = Number(qtyButton.getAttribute('data-cod-qty-step') || 0);
      const qtyInput = dialog.querySelector(`[data-cod-qty-input][data-cod-line="${line}"]`);
      const currentQuantity = Number(
        qtyInput?.value || qtyInput?.getAttribute('data-cod-quantity') || 1
      );
      const nextQuantity = Math.max(1, currentQuantity + step);

      if (qtyInput) {
        qtyInput.value = String(nextQuantity);
      }

      void handleCartQuantityUpdate(line, nextQuantity);
    });

    dialog.addEventListener('change', function (e) {
      const qtyInput = e.target.closest('[data-cod-qty-input]');
      if (!qtyInput || isCartQuantityUpdateInFlight) return;

      const line = qtyInput.getAttribute('data-cod-line');
      const previousQuantity = Number(qtyInput.getAttribute('data-cod-quantity') || 1);
      const nextQuantity = Number(qtyInput.value);

      if (!Number.isInteger(nextQuantity) || nextQuantity < 1) {
        qtyInput.value = String(previousQuantity);
        return;
      }

      if (nextQuantity === previousQuantity) {
        return;
      }

      void handleCartQuantityUpdate(line, nextQuantity);
    });

    dialog.addEventListener('keydown', function (e) {
      const qtyInput = e.target.closest('[data-cod-qty-input]');
      if (!qtyInput || e.key !== 'Enter') return;

      e.preventDefault();
      qtyInput.blur();
    });

    document.getElementById('cod-wilaya').addEventListener('change', async function () {
      await renderCityOptions();
      await renderShippingMethods('home');
      await renderCart();
    });

    document.getElementById('cod-city').addEventListener('change', async function () {
      await renderShippingMethods('home');
      await renderCart();
    });

    document.getElementById('cod-confirm').addEventListener('click', async function () {
      const btn = this;
      if (btn.dataset.loading === '1') return;
      btn.dataset.loading = '1';

      const fields = {
        firstName: document.getElementById('cod-firstName').value.trim(),
        lastName: document.getElementById('cod-lastName').value.trim(),
        phone: document.getElementById('cod-phone').value.trim(),
        email: document.getElementById('cod-email').value.trim(),
        address: document.getElementById('cod-address').value.trim(),
        city: document.getElementById('cod-city').value.trim(),
        wilaya: document.getElementById('cod-wilaya').value,
      };
      const customerNote = document.getElementById('cod-note').value.trim();

      const requiredFields = {
        firstName: fields.firstName,
        lastName: fields.lastName,
        phone: fields.phone,
        address: fields.address,
        city: fields.city,
        wilaya: fields.wilaya
      };

      const emailInput = document.getElementById('cod-email');
      if (fields.email && emailInput && !emailInput.checkValidity()) {
        alert('Veuillez saisir un email valide.');
        btn.dataset.loading = '0';
        return;
      }

      const empty = Object.entries(requiredFields).find(([, v]) => !v);
      if (empty) {
        const map = {
          firstName: 'Prénom',
          lastName: 'Nom',
          phone: 'Téléphone',
          address: 'Adresse',
          city: 'Ville',
          wilaya: 'Wilaya'
        };
        alert(`Veuillez remplir le champ : ${map[empty[0]]}`);
        btn.dataset.loading = '0';
        return;
      }

      btn.disabled = true;
      setCodSubmittingState(true);
      btn.innerHTML = 'Création de la commande...';

      try {
        const cart = await fetch('/cart.js', {
          headers: { Accept: 'application/json' }
        }).then(r => r.json());

        if (!cart.items || !cart.items.length) {
          throw new Error('Panier vide');
        }

        const settings = await getMetaSettings();
        const shippingOptions = getShippingOptions(settings.shippingFees || {}, fields.wilaya);
        const activeShipping = shippingOptions.find(option => option.id === getSelectedShippingMethod()) || shippingOptions[0] || null;

        if (!activeShipping) {
          throw new Error('Desole, nous ne livrons pas a cette wilaya pour le moment.');
        }

        const shippingMethod = activeShipping.id;
        const subtotal = moneyFromCents(cart.total_price || 0);
        const shippingPrice = Number(activeShipping.price.toFixed(2));
        const totalValue = Number((subtotal + shippingPrice).toFixed(2));
        const tracking = {
          ...buildMetaTrackingDetails(),
          currency: cart.currency || 'DZD',
          subtotal,
          shippingPrice,
          totalValue
        };

        const payload = {
          customer: fields,
          note: customerNote,
          shipping: {
            method: shippingMethod
          },
          tracking,
          items: cart.items.map(item => ({
            variant_id: item.variant_id,
            product_id: item.product_id,
            quantity: item.quantity,
            price: moneyFromCents(item.final_price || item.price || 0),
            title: item.product_title || '',
            sku: item.sku || ''
          }))
        };

        const res = await fetch('/apps/cod/create-order', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'Accept': 'application/json'
          },
          credentials: 'same-origin',
          body: JSON.stringify(payload)
        });

        const raw = await res.text();
        const contentType = res.headers.get('content-type') || '';
        let result = null;

        try {
          result = raw ? JSON.parse(raw) : null;
        } catch (parseError) {
          console.error('[COD] invalid JSON response:', {
            status: res.status,
            statusText: res.statusText,
            contentType,
            body: raw,
            parseError
          });
          throw new Error('Reponse invalide du serveur de commande');
        }

        if (!contentType.includes('application/json')) {
          console.warn('[COD] unexpected response content-type:', {
            status: res.status,
            statusText: res.statusText,
            contentType,
            body: result || raw
          });
        }

        if (!res.ok || !result || result.success !== true) {
          console.error('[COD] order creation failed:', {
            status: res.status,
            statusText: res.statusText,
            body: result || raw
          });
          
          throw new Error(result?.error || 'Erreur lors de la création de la commande');
        }

        console.log('[COD] order created:', {
          orderId: result.orderId,
          orderName: result.orderName
        });

        try {
          await trackMetaPurchaseEvent({
            cart,
            tracking,
            orderId: result.orderId,
            orderName: result.orderName
          });
        } catch (metaError) {
          console.error('[COD] Meta browser Purchase event error:', metaError);
        }

        persistThankYouPageData({
          orderName: result.orderName || '',
          customer: {
            firstName: fields.firstName,
            lastName: fields.lastName,
            email: fields.email,
            phone: fields.phone,
            address: fields.address,
            city: fields.city,
            wilaya: fields.wilaya
          },
          paymentMethodLabel: 'Paiement a la livraison',
          shippingMethodLabel: activeShipping?.label || 'Livraison',
          contactPhone: '+213 551 639 560',
          storeUrl: window.location.origin,
          subtotal,
          shippingPrice,
          totalValue,
          currency: tracking.currency || 'DZD',
          items: (cart.items || []).map(item => ({
            title: item.product_title || '',
            variantTitle: item.variant_title || '',
            image: item.image || '',
            quantity: Number(item.quantity) || 1,
            linePrice: moneyFromCents(item.line_price || 0)
          }))
        });

        const cartCleared = await clearCartAndVerify();

        if (!cartCleared) {
          throw new Error('Commande creee, mais le panier est toujours plein');
        }

        window.location.href = getThankYouUrl();
      } catch (err) {
        console.error('[COD]', err);
        setCodSubmittingState(false);
        alert(err.message || 'Impossible de créer la commande.');
        btn.disabled = false;
        btn.dataset.loading = '0';
        btn.innerHTML = 'COMMANDER';
      }
    });

    dialog.showModal();

    requestAnimationFrame(() => requestAnimationFrame(() => {
      document.getElementById('cod-panel')?.classList.add('cod-open');
    }));

    void getMetaSettings();
    void renderWilayaOptions();
    void renderCityOptions();
    void renderShippingMethods('home');
    void renderCart();
  }

  function injectCartDrawerButton() {
    if (document.getElementById('cod-cart-btn')) return;

    const checkoutSelectors = [
      'cart-drawer button[name="checkout"]',
      'cart-drawer input[name="checkout"]',
      'cart-drawer a[href="/checkout"]',
      '.cart-drawer button[name="checkout"]',
      '.cart-drawer input[name="checkout"]',
      '.cart-drawer a[href="/checkout"]',
      '.drawer button[name="checkout"]',
      '.drawer input[name="checkout"]',
    ];

    let original = null;
    for (const sel of checkoutSelectors) {
      original = document.querySelector(sel);
      if (original) break;
    }
    if (!original) return;

    original.style.display = 'none';

    const btn = document.createElement('button');
    btn.id = 'cod-cart-btn';
    btn.type = 'button';
    btn.className = original.className;
    btn.textContent = 'COMMANDER';

    btn.style.cssText = `
      display:block;
      width:100%;
      margin-top:8px;
      padding:14px;
      background:${COD_BUTTON_BACKGROUND};
      color:${COD_BUTTON_TEXT};
      border:none;
      border-radius:8px;
      font-size:15px;
      font-weight:700;
      cursor:pointer;
      font-family:inherit;
      text-align:center;
    `;

    btn.addEventListener('click', function (e) {
      e.preventDefault();
      e.stopPropagation();
      void fetchCart()
        .then(cart => trackMetaBrowserEvent('InitiateCheckout', buildCartMetaParams(cart)))
        .catch(error => console.error('[COD] Meta InitiateCheckout tracking failed:', error));
      tryCloseThemeCart();
      setTimeout(openCodDrawer, 120);
    });

    original.parentNode.insertBefore(btn, original.nextSibling);
  }

  function injectProductButton() {
    if (!window.location.pathname.includes('/products/')) return;

    const atcSelectors = [
      'product-form button[type="submit"]',
      'form[action*="/cart/add"] button[type="submit"]',
      '.product-form__submit',
      'button[name="add"]',
    ];

    function isVisible(el) {
      if (!el) return false;
      const style = window.getComputedStyle(el);
      return (
        style.display !== 'none' &&
        style.visibility !== 'hidden' &&
        el.getClientRects().length > 0
      );
    }

    let atcBtn = null;
    for (const sel of atcSelectors) {
      const matches = Array.from(document.querySelectorAll(sel));
      atcBtn = matches.find(isVisible) || matches[0] || null;
      if (atcBtn) break;
    }
    if (!atcBtn) return;

    const existingBtn = document.getElementById('cod-product-btn');
    if (existingBtn) {
      const sameContainer = existingBtn.parentNode === atcBtn.parentNode;
      const samePosition = existingBtn.previousElementSibling === atcBtn;
      if (sameContainer && samePosition && isVisible(existingBtn)) return;
      existingBtn.remove();
    }

    const form =
      atcBtn.closest('form') ||
      document.querySelector('product-form form, form[action*="/cart/add"], .product-form form');

    if (form && form.dataset.codMetaAtcBound !== '1') {
      form.dataset.codMetaAtcBound = '1';
      form.addEventListener('submit', function () {
        void trackMetaBrowserEvent('AddToCart', buildAddToCartParamsFromForm(form));
      });
    }

    document
      .querySelectorAll('.shopify-payment-button, [data-shopify="payment-button"]')
      .forEach(function (dpb) {
        if (isVisible(dpb)) dpb.style.display = 'none';
      });

    const btn = document.createElement('button');
    btn.id = 'cod-product-btn';
    btn.type = 'button';
    btn.textContent = 'Acheter maintenant';
    btn.className = atcBtn.className;

    btn.style.cssText = `
      display:block;
      width:100%;
      margin-top:10px;
      padding:14px;
      background:${COD_BUTTON_BACKGROUND};
      color:${COD_BUTTON_TEXT};
      border:none;
      border-radius:8px;
      font-size:15px;
      font-weight:700;
      cursor:pointer;
      font-family:inherit;
      text-align:center;
    `;

    btn.addEventListener('click', async function (e) {
      e.preventDefault();
      e.stopPropagation();

      btn.textContent = '...';
      btn.disabled = true;

      if (form) {
        try {
          const res = await fetch('/cart/add.js', {
            method: 'POST',
            headers: { Accept: 'application/json' },
            body: new FormData(form),
          });
          if (!res.ok) throw new Error('add to cart failed');

          const addedItem = await res.json();
          await trackMetaBrowserEvent('AddToCart', buildAddToCartParamsFromItem(addedItem));

          const updatedCart = await fetchCart();
          await trackMetaBrowserEvent('InitiateCheckout', buildCartMetaParams(updatedCart));
        } catch (err) {
          console.error('[COD] add to cart error:', err);
        }
      }

      btn.textContent = 'Acheter maintenant';
      btn.disabled = false;

      openCodDrawer();
    });

    atcBtn.parentNode.insertBefore(btn, atcBtn.nextSibling);
  }

  let observerDebounce = null;

  const observer = new MutationObserver(function () {
    clearTimeout(observerDebounce);
    observerDebounce = setTimeout(function () {
      injectCartDrawerButton();
      injectProductButton();
    }, 80);
  });

  observer.observe(document.body, { childList: true, subtree: true });

  function init() {
    void ensureMetaPixelReady();
    injectCartDrawerButton();
    injectProductButton();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
})();
</script>

