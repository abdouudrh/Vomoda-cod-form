{% schema %}
{
  "name": "COD Cart Drawer",
  "target": "body",
  "settings": []
}
{% endschema %}

<style>
  #cod-dialog {
    border: none;
    padding: 0;
    margin: 0;
    width: 100%;
    max-width: 100%;
    height: 100%;
    max-height: 100%;
    background: transparent;
    overflow: hidden;
  }

  #cod-dialog::backdrop {
    background: rgba(0, 0, 0, 0.4);
  }

  #cod-panel {
    position: fixed;
    top: 0;
    right: 0;
    width: 420px;
    max-width: 100vw;
    height: 100dvh;
    background: #ffffff;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    transform: translateX(100%);
    transition: transform 0.28s cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow: -8px 0 32px rgba(0, 0, 0, 0.12);
    z-index: 999999;
  }

  #cod-panel.cod-open {
    transform: translateX(0);
  }

  .cod-loading-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    gap: 16px;
    background: rgba(255, 255, 255, 0.94);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.18s ease;
    z-index: 3;
  }

  .cod-loading-overlay.is-visible {
    opacity: 1;
    pointer-events: auto;
  }

  .cod-loading-spinner {
    position: relative;
    width: 72px;
    height: 72px;
  }

  .cod-loading-spinner-dot {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 12px;
    height: 12px;
    margin: -6px 0 0 -6px;
    border-radius: 999px;
    background: #ff6a1a;
    opacity: 0.14;
    animation: cod-loading-fade 1s linear infinite;
  }

  .cod-loading-spinner-dot:nth-child(1) {
    transform: translateY(-28px);
    animation-delay: -0.875s;
  }

  .cod-loading-spinner-dot:nth-child(2) {
    transform: rotate(45deg) translateY(-28px);
    animation-delay: -0.75s;
  }

  .cod-loading-spinner-dot:nth-child(3) {
    transform: rotate(90deg) translateY(-28px);
    animation-delay: -0.625s;
  }

  .cod-loading-spinner-dot:nth-child(4) {
    transform: rotate(135deg) translateY(-28px);
    animation-delay: -0.5s;
  }

  .cod-loading-spinner-dot:nth-child(5) {
    transform: rotate(180deg) translateY(-28px);
    animation-delay: -0.375s;
  }

  .cod-loading-spinner-dot:nth-child(6) {
    transform: rotate(225deg) translateY(-28px);
    animation-delay: -0.25s;
  }

  .cod-loading-spinner-dot:nth-child(7) {
    transform: rotate(270deg) translateY(-28px);
    animation-delay: -0.125s;
  }

  .cod-loading-spinner-dot:nth-child(8) {
    transform: rotate(315deg) translateY(-28px);
    animation-delay: 0s;
  }

  .cod-loading-text {
    margin: 0;
    font-size: 14px;
    font-weight: 600;
    color: #ff6a1a;
    text-align: center;
  }

  @keyframes cod-loading-fade {
    0% {
      opacity: 1;
    }

    100% {
      opacity: 0.14;
    }
  }

  .cod-field {
    width: 100%;
    height: 46px;
    padding: 0 14px;
    border: 1.5px solid #e0e0e0;
    border-radius: 8px;
    box-sizing: border-box;
    font-size: 14px;
    font-family: inherit;
    color: #111;
    background: #fff;
    outline: none;
    transition: border-color 0.15s;
    display: block;
    -webkit-appearance: none;
    appearance: none;
  }

  .cod-field:focus {
    border-color: #111;
  }

  .cod-field::placeholder {
    color: #aaa;
  }

  .cod-field:disabled {
    background: #f3f4f6;
    color: #8a8a8a;
    border-color: #e5e7eb;
    cursor: not-allowed;
  }
</style>

<script>
(function () {
  'use strict';

  if (window.__codInitialized) return;
  window.__codInitialized = true;

  const COD_BUTTON_BACKGROUND = '#ff6a1a';
  const COD_BUTTON_TEXT = '#fff';

  function normalizeWilayaName(value) {
    return (value || '')
      .normalize('NFD')
      .replace(/[\u0300-\u036f]/g, '')
      .replace(/[^a-zA-Z0-9]+/g, ' ')
      .trim()
      .replace(/\s+/g, ' ')
      .toLowerCase();
  }

  function emptyCodSettings() {
    return {
      metaEnabled: false,
      metaPixelId: '',
      shippingFees: {}
    };
  }

  function normalizeOptionalShippingFee(value) {
    if (typeof value !== 'number' || !Number.isFinite(value) || value < 0) {
      return null;
    }

    return Number(value.toFixed(2));
  }

  function getShippingConfigForWilaya(shippingFees, wilaya) {
    if (!shippingFees || !wilaya) return null;

    const normalizedWilaya = normalizeWilayaName(wilaya);
    const matchedKey = Object.keys(shippingFees).find(key => normalizeWilayaName(key) === normalizedWilaya);

    return matchedKey ? shippingFees[matchedKey] : null;
  }

  function getShippingOptions(shippingFees, wilaya) {
    const config = getShippingConfigForWilaya(shippingFees, wilaya);
    if (!config) return [];

    const options = [];
    const homePrice = normalizeOptionalShippingFee(config.home);
    const stopDeskPrice = normalizeOptionalShippingFee(config.stopDesk);

    if (homePrice !== null) {
      options.push({
        id: 'home',
        label: 'Livraison a domicile',
        price: homePrice
      });
    }

    if (stopDeskPrice !== null) {
      options.push({
        id: 'stop_desk',
        label: 'Stop desk',
        price: stopDeskPrice
      });
    }

    return options;
  }

  function getSelectedShippingMethod() {
    return document.querySelector('input[name="cod-shipping-method"]:checked')?.value || '';
  }

  function hasSelectedDeliveryLocation() {
    const wilaya = document.getElementById('cod-wilaya')?.value || '';
    const city = document.getElementById('cod-city')?.value || '';
    return Boolean(wilaya && city);
  }

  function getCookieValue(name) {
    const escapedName = name.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
    const match = document.cookie.match(new RegExp(`(?:^|; )${escapedName}=([^;]*)`));
    return match ? decodeURIComponent(match[1]) : '';
  }

  function buildMetaTrackingDetails() {
    const pageUrl = new URL(window.location.href);
    const fbclid = pageUrl.searchParams.get('fbclid') || '';
    const cookieFbp = getCookieValue('_fbp');
    const cookieFbc = getCookieValue('_fbc');
    const eventId = `cod_${Date.now()}_${Math.random().toString(36).slice(2, 10)}`;

    return {
      eventId,
      fbp: cookieFbp,
      fbc: cookieFbc || (fbclid ? `fb.1.${Date.now()}.${fbclid}` : ''),
      fbclid,
      eventSourceUrl: pageUrl.toString(),
      referrer: document.referrer || '',
      userAgent: navigator.userAgent || '',
      language: navigator.language || '',
      utmSource: pageUrl.searchParams.get('utm_source') || '',
      utmMedium: pageUrl.searchParams.get('utm_medium') || '',
      utmCampaign: pageUrl.searchParams.get('utm_campaign') || '',
      utmContent: pageUrl.searchParams.get('utm_content') || '',
      utmTerm: pageUrl.searchParams.get('utm_term') || ''
    };
  }

  function moneyFromCents(value) {
    return Number((Number(value || 0) / 100).toFixed(2));
  }

  let metaSettingsPromise = null;
  let metaPixelScriptPromise = null;

  async function getMetaSettings() {
    if (window.__codMetaSettings) {
      return window.__codMetaSettings;
    }

    if (!metaSettingsPromise) {
      metaSettingsPromise = fetch('/apps/cod/settings', {
        headers: { Accept: 'application/json' },
        credentials: 'same-origin'
      })
        .then(async response => {
          const raw = await response.text();
          let result = null;

          try {
            result = raw ? JSON.parse(raw) : null;
          } catch (error) {
            console.error('[COD] invalid Meta settings response:', {
              status: response.status,
              statusText: response.statusText,
              body: raw,
              error
            });
            return emptyCodSettings();
          }

          const settings = result?.success === true && result?.settings
            ? {
                metaEnabled: Boolean(result.settings.metaEnabled),
                metaPixelId: String(result.settings.metaPixelId || '').trim(),
                shippingFees: result.settings.shippingFees && typeof result.settings.shippingFees === 'object'
                  ? result.settings.shippingFees
                  : {}
              }
            : emptyCodSettings();

          window.__codMetaSettings = settings;
          return settings;
        })
        .catch(error => {
          console.error('[COD] Meta settings loading failed:', error);
          return emptyCodSettings();
        });
    }

    return metaSettingsPromise;
  }

  function ensureFbqStub() {
    if (typeof window.fbq === 'function') {
      return window.fbq;
    }

    const fbq = function () {
      if (fbq.callMethod) {
        fbq.callMethod.apply(fbq, arguments);
      } else {
        fbq.queue.push(arguments);
      }
    };

    if (!window._fbq) {
      window._fbq = fbq;
    }

    fbq.push = fbq;
    fbq.loaded = true;
    fbq.version = '2.0';
    fbq.queue = [];
    window.fbq = fbq;

    return fbq;
  }

  function loadMetaPixelScript() {
    if (typeof window.fbq === 'function' && window.fbq.callMethod) {
      return Promise.resolve(window.fbq);
    }

    ensureFbqStub();

    if (!metaPixelScriptPromise) {
      metaPixelScriptPromise = new Promise((resolve, reject) => {
        const existing = document.getElementById('cod-meta-pixel-script');

        if (existing) {
          existing.addEventListener('load', () => resolve(window.fbq), { once: true });
          existing.addEventListener('error', () => reject(new Error('Meta Pixel script failed to load')), { once: true });
          return;
        }

        const script = document.createElement('script');
        script.id = 'cod-meta-pixel-script';
        script.async = true;
        script.src = 'https://connect.facebook.net/en_US/fbevents.js';
        script.onload = () => resolve(window.fbq);
        script.onerror = () => {
          metaPixelScriptPromise = null;
          reject(new Error('Meta Pixel script failed to load'));
        };

        const anchor = document.getElementsByTagName('script')[0];
        if (anchor && anchor.parentNode) {
          anchor.parentNode.insertBefore(script, anchor);
        } else {
          document.head.appendChild(script);
        }
      });
    }

    return metaPixelScriptPromise;
  }

  async function ensureMetaPixelReady() {
    const settings = await getMetaSettings();

    if (!settings.metaEnabled || !settings.metaPixelId) {
      return null;
    }

    await loadMetaPixelScript();

    if (!window.__codMetaPixelIds) {
      window.__codMetaPixelIds = {};
    }

    if (!window.__codMetaPixelIds[settings.metaPixelId]) {
      window.fbq('init', settings.metaPixelId);
      window.__codMetaPixelIds[settings.metaPixelId] = true;
    }

    if (!window.__codMetaPageViewTracked) {
      window.fbq('track', 'PageView');
      window.__codMetaPageViewTracked = true;
    }

    return settings;
  }

  async function trackMetaPurchaseEvent({ cart, tracking, orderId, orderName }) {
    if (!tracking?.eventId) {
      return;
    }

    const settings = await ensureMetaPixelReady();
    if (!settings || typeof window.fbq !== 'function') {
      return;
    }

    if (!window.__codTrackedMetaEvents) {
      window.__codTrackedMetaEvents = {};
    }

    if (window.__codTrackedMetaEvents[tracking.eventId]) {
      return;
    }

    const contents = (cart.items || [])
      .map(item => ({
        id: String(item.product_id || item.variant_id || ''),
        quantity: Number(item.quantity) || 1,
        item_price: moneyFromCents(item.final_price || item.price || 0)
      }))
      .filter(item => item.id);

    const params = {
      currency: tracking.currency || 'DZD',
      value: Number(tracking.totalValue || 0),
      content_type: 'product',
      content_ids: contents.map(item => item.id),
      contents,
      num_items: (cart.items || []).reduce((sum, item) => sum + (Number(item.quantity) || 0), 0),
      order_id: orderName || orderId || tracking.eventId
    };

    window.fbq('track', 'Purchase', params, { eventID: tracking.eventId });
    window.__codTrackedMetaEvents[tracking.eventId] = true;
  }

  function getActiveCurrency() {
    return window.Shopify?.currency?.active || window.Shopify?.currency?.currency || 'DZD';
  }

  function buildCartMetaParams(cart) {
    const contents = (cart.items || [])
      .map(item => ({
        id: String(item.product_id || item.variant_id || ''),
        quantity: Number(item.quantity) || 1,
        item_price: moneyFromCents(item.final_price || item.price || 0)
      }))
      .filter(item => item.id);

    return {
      currency: cart.currency || getActiveCurrency(),
      value: moneyFromCents(cart.total_price || 0),
      content_type: 'product',
      content_ids: contents.map(item => item.id),
      contents,
      num_items: (cart.items || []).reduce((sum, item) => sum + (Number(item.quantity) || 0), 0)
    };
  }

  function buildAddToCartParamsFromForm(form) {
    const formData = new FormData(form);
    const variantId = String(formData.get('id') || formData.get('variant_id') || '').trim();
    const quantity = Math.max(1, Number(formData.get('quantity') || 1));
    const contents = variantId
      ? [{ id: variantId, quantity }]
      : [];

    return {
      currency: getActiveCurrency(),
      value: 0,
      content_type: 'product',
      content_ids: contents.map(item => item.id),
      contents,
      num_items: quantity
    };
  }

  function buildAddToCartParamsFromItem(item) {
    const quantity = Math.max(1, Number(item?.quantity) || 1);
    const itemPriceCents = Number(item?.final_price || item?.price || 0);
    const itemId = String(item?.product_id || item?.variant_id || '').trim();
    const contents = itemId
      ? [{ id: itemId, quantity, item_price: moneyFromCents(itemPriceCents) }]
      : [];

    return {
      currency: getActiveCurrency(),
      value: Number((moneyFromCents(itemPriceCents) * quantity).toFixed(2)),
      content_type: 'product',
      content_ids: contents.map(content => content.id),
      contents,
      num_items: quantity
    };
  }

  async function trackMetaBrowserEvent(eventName, params) {
    const settings = await ensureMetaPixelReady();
    if (!settings || typeof window.fbq !== 'function') {
      return;
    }

    window.fbq('track', eventName, params);
  }

  let locationDataPromise = null;

  function getWilayaLocationData(locations, wilaya) {
    if (!locations || !wilaya) return null;

    if (locations[wilaya]) {
      return locations[wilaya];
    }

    const normalizedWilaya = normalizeWilayaName(wilaya);
    const matchedKey = Object.keys(locations).find(
      key => normalizeWilayaName(key) === normalizedWilaya
    );

    return matchedKey ? locations[matchedKey] : null;
  }

  async function getLocationData() {
    if (window.__codLocationData) {
      return window.__codLocationData;
    }

    if (!locationDataPromise) {
      locationDataPromise = fetch('/apps/cod/locations', {
        headers: { Accept: 'application/json' },
        credentials: 'same-origin'
      })
        .then(async response => {
          const raw = await response.text();
          let result = null;

          try {
            result = raw ? JSON.parse(raw) : null;
          } catch (error) {
            console.error('[COD] invalid locations response:', {
              status: response.status,
              statusText: response.statusText,
              body: raw,
              error
            });
            throw new Error('Reponse invalide du serveur des localites');
          }

          if (!response.ok || !result || result.success !== true || !result.wilayas) {
            console.error('[COD] locations loading failed:', {
              status: response.status,
              statusText: response.statusText,
              body: result || raw
            });
            throw new Error(result?.error || 'Impossible de charger les localites');
          }

          window.__codLocationData = result.wilayas;
          return result.wilayas;
        })
        .catch(error => {
          locationDataPromise = null;
          throw error;
        });
    }

    return locationDataPromise;
  }

  async function renderWilayaOptions(preferredWilaya = '') {
    const wilayaEl = document.getElementById('cod-wilaya');

    if (!wilayaEl) return;

    wilayaEl.innerHTML = '';
    wilayaEl.disabled = true;

    const loadingOption = document.createElement('option');
    loadingOption.value = '';
    loadingOption.textContent = 'Chargement...';
    wilayaEl.appendChild(loadingOption);

    try {
      const locations = await getLocationData();
      const wilayaEntries = Object.entries(locations).sort(([, a], [, b]) => {
        const codeA = Number(a?.code || 0);
        const codeB = Number(b?.code || 0);
        return codeA - codeB;
      });

      wilayaEl.innerHTML = '';

      const placeholderOption = document.createElement('option');
      placeholderOption.value = '';
      placeholderOption.textContent = 'Wilaya';
      wilayaEl.appendChild(placeholderOption);

      wilayaEntries.forEach(([wilayaName, wilayaData]) => {
        const option = document.createElement('option');
        option.value = wilayaName;
        option.textContent = `${String(wilayaData.code).padStart(2, '0')} - ${wilayaName}`;
        wilayaEl.appendChild(option);
      });

      wilayaEl.disabled = false;

      const normalizedPreferred = normalizeWilayaName(preferredWilaya);
      const matchedWilaya = wilayaEntries.find(
        ([wilayaName]) => normalizeWilayaName(wilayaName) === normalizedPreferred
      );

      wilayaEl.value = matchedWilaya ? matchedWilaya[0] : '';
    } catch (error) {
      console.error('[COD] wilaya loading error:', error);
      wilayaEl.innerHTML = '';

      const errorOption = document.createElement('option');
      errorOption.value = '';
      errorOption.textContent = 'Impossible de charger les wilayas';
      wilayaEl.appendChild(errorOption);
      wilayaEl.disabled = true;
    }
  }

  async function renderCityOptions(preferredCity = '') {
    const cityEl = document.getElementById('cod-city');
    const wilaya = document.getElementById('cod-wilaya')?.value || '';

    if (!cityEl) return;

    cityEl.innerHTML = '';

    const defaultOption = document.createElement('option');
    defaultOption.value = '';

    if (!wilaya) {
      defaultOption.textContent = 'Choisissez une wilaya d\'abord';
      cityEl.appendChild(defaultOption);
      cityEl.disabled = true;
      return;
    }

    defaultOption.textContent = 'Chargement...';
    cityEl.appendChild(defaultOption);
    cityEl.disabled = true;

    try {
      const locations = await getLocationData();
      const wilayaData = getWilayaLocationData(locations, wilaya);
      const communes = Array.isArray(wilayaData?.communes) ? wilayaData.communes : [];

      cityEl.innerHTML = '';

      const placeholderOption = document.createElement('option');
      placeholderOption.value = '';
      placeholderOption.textContent = communes.length
        ? 'Province / Commune'
        : 'Aucune commune disponible';
      cityEl.appendChild(placeholderOption);

      if (!communes.length) {
        cityEl.disabled = true;
        return;
      }

      communes.forEach(commune => {
        const option = document.createElement('option');
        option.value = commune;
        option.textContent = commune;
        cityEl.appendChild(option);
      });

      cityEl.disabled = false;
      cityEl.value = communes.includes(preferredCity) ? preferredCity : '';
    } catch (error) {
      console.error('[COD] location loading error:', error);
      cityEl.innerHTML = '';

      const errorOption = document.createElement('option');
      errorOption.value = '';
      errorOption.textContent = 'Impossible de charger les communes';
      cityEl.appendChild(errorOption);
      cityEl.disabled = true;
    }
  }

  async function fetchCart() {
    const r = await fetch('/cart.js', { headers: { Accept: 'application/json' } });
    if (!r.ok) throw new Error('cart fetch failed');
    return r.json();
  }

  function notifyCartUpdated(cart) {
    const detail = { cart };

    try {
      if (window.Shopify && typeof window.Shopify.onCartUpdate === 'function') {
        window.Shopify.onCartUpdate(cart);
      }
    } catch (error) {
      console.warn('[COD] Shopify.onCartUpdate failed:', error);
    }

    ['cart:refresh', 'cart:updated', 'cart:change'].forEach(eventName => {
      document.dispatchEvent(new CustomEvent(eventName, { bubbles: true, detail }));
      window.dispatchEvent(new CustomEvent(eventName, { detail }));
    });
  }

  async function updateCartLineQuantity(line, quantity) {
    const parsedLine = Number(line);
    const parsedQuantity = Number(quantity);

    if (!Number.isInteger(parsedLine) || parsedLine < 1) {
      throw new Error('Ligne de panier invalide.');
    }

    if (!Number.isInteger(parsedQuantity) || parsedQuantity < 0) {
      throw new Error('Quantite invalide.');
    }

    const response = await fetch('/cart/change.js', {
      method: 'POST',
      headers: {
        Accept: 'application/json',
        'Content-Type': 'application/json',
        'X-Requested-With': 'XMLHttpRequest'
      },
      credentials: 'same-origin',
      body: JSON.stringify({
        line: parsedLine,
        quantity: parsedQuantity
      })
    });

    const raw = await response.text();
    let cart = null;

    try {
      cart = raw ? JSON.parse(raw) : null;
    } catch (error) {
      console.error('[COD] invalid cart/change response:', {
        status: response.status,
        statusText: response.statusText,
        body: raw,
        error
      });
      throw new Error('Reponse invalide lors de la mise a jour du panier.');
    }

    if (!response.ok || !cart) {
      throw new Error(cart?.description || 'Impossible de mettre a jour la quantite.');
    }

    notifyCartUpdated(cart);
    return cart;
  }

  function setCartQuantityControlsDisabled(disabled) {
    document
      .querySelectorAll('[data-cod-qty-step], [data-cod-qty-input], [data-cod-remove-line]')
      .forEach(control => {
        control.disabled = disabled;
      });
  }

  function setCodSubmittingState(submitting) {
    const panel = document.getElementById('cod-panel');
    const overlay = document.getElementById('cod-loading-overlay');
    const closeButton = document.getElementById('cod-close');

    if (panel) {
      panel.dataset.submitting = submitting ? '1' : '0';
    }

    if (overlay) {
      overlay.classList.toggle('is-visible', Boolean(submitting));
      overlay.setAttribute('aria-hidden', submitting ? 'false' : 'true');
    }

    if (closeButton) {
      closeButton.disabled = Boolean(submitting);
      closeButton.style.opacity = submitting ? '0.5' : '1';
      closeButton.style.cursor = submitting ? 'not-allowed' : 'pointer';
    }
  }

  let isCartQuantityUpdateInFlight = false;

  async function handleCartQuantityUpdate(line, quantity) {
    if (isCartQuantityUpdateInFlight) return;

    const parsedQuantity = Number(quantity);
    if (!Number.isInteger(parsedQuantity) || parsedQuantity < 1) {
      throw new Error('Quantite invalide.');
    }

    isCartQuantityUpdateInFlight = true;
    setCartQuantityControlsDisabled(true);

    try {
      const updatedCart = await updateCartLineQuantity(line, parsedQuantity);
      await renderCart(updatedCart);
    } catch (error) {
      console.error('[COD] cart quantity update failed:', error);
      alert(error.message || 'Impossible de mettre a jour la quantite.');
      await renderCart();
    } finally {
      isCartQuantityUpdateInFlight = false;
      setCartQuantityControlsDisabled(false);
    }
  }

  async function handleCartLineRemoval(line) {
    if (isCartQuantityUpdateInFlight) return;

    isCartQuantityUpdateInFlight = true;
    setCartQuantityControlsDisabled(true);

    try {
      const updatedCart = await updateCartLineQuantity(line, 0);
      await renderCart(updatedCart);
    } catch (error) {
      console.error('[COD] cart line removal failed:', error);
      alert(error.message || 'Impossible de supprimer le produit.');
      await renderCart();
    } finally {
      isCartQuantityUpdateInFlight = false;
      setCartQuantityControlsDisabled(false);
    }
  }

  function getThankYouUrl() {
    return new URL('/pages/thank-you', window.location.origin).toString();
  }

  function persistThankYouPageData(data) {
    try {
      const payload = JSON.stringify({
        ...data,
        savedAt: Date.now()
      });
      window.sessionStorage.setItem('codThankYouData', payload);
      window.localStorage.setItem('codThankYouData', payload);
    } catch (error) {
      console.error('[COD] thank you page data persistence failed:', error);
    }
  }

  async function clearCartAndVerify() {
    for (let attempt = 0; attempt < 2; attempt += 1) {
      const clearCartRes = await fetch('/cart/clear.js', {
        method: 'POST',
        headers: {
          Accept: 'application/json',
          'X-Requested-With': 'XMLHttpRequest'
        },
        credentials: 'same-origin'
      });

      if (!clearCartRes.ok) {
        continue;
      }

      await new Promise(resolve => setTimeout(resolve, 200));

      const updatedCart = await fetchCart();
      if (!updatedCart.items?.length && !updatedCart.item_count) {
        return true;
      }
    }

    return false;
  }

  function tryCloseThemeCart() {
    const closeBtn = document.querySelector(
      'cart-drawer [id*="close"], cart-drawer button[aria-label*="lose"], ' +
      '.cart-drawer button[aria-label*="lose"], .drawer button[aria-label*="lose"]'
    );
    if (closeBtn) {
      closeBtn.click();
      return;
    }

    document.dispatchEvent(new CustomEvent('cart:close', { bubbles: true }));
    document.dispatchEvent(new CustomEvent('drawer:close', { bubbles: true }));

    const cartDrawerEl = document.querySelector('cart-drawer');
    if (cartDrawerEl && typeof cartDrawerEl.close === 'function') {
      cartDrawerEl.close();
    }

    const openClasses = ['is-open', 'active', 'open', 'js-drawer-open', 'drawer-open'];
    document.documentElement.classList.remove(...openClasses);
    document.body.classList.remove(...openClasses);
  }

  async function renderCart(cartData = null) {
    const summaryEl = document.getElementById('cod-summary');
    const totalEl = document.getElementById('cod-total');
    if (!summaryEl || !totalEl) return;

    summaryEl.innerHTML = '<p style="color:#888;font-size:14px;">Chargement…</p>';

